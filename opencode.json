{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md"
  ],
  "lsp": {
    "gopls": {
      "command": [
        "gopls"
      ],
      "extensions": [
        ".go"
      ]
    },
    "gdscript": {
      "command": [
        "./gdscript-lsp/bin/gdscript-lsp-proxy"
      ],
      "extensions": [
        ".gd"
      ],
      "env": {
        "GODOT_LSP_PORT": "6005"
      }
    }
  }
}
